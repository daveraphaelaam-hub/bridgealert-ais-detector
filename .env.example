# Copy this file to .env for local development.
# NEVER commit .env to GitHub — it contains secret keys.

# Your AISstream.io API key
AIS_API_KEY=your_aisstream_api_key_here

# Google Sheet ID
# Get this from your sheet's URL:
# https://docs.google.com/spreadsheets/d/THIS_IS_THE_ID/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Google Service Account credentials (the full contents of your JSON key file)
# Paste the entire JSON on one line, or use single quotes in shell
GOOGLE_CREDENTIALS={"type":"service_account","project_id":"..."}

# Port for health check endpoint (Render/Railway set this automatically)
PORT=3000
